# Frontend Environment Configuration for Refactored Backend

# API URLs for new domain architecture
VITE_PAYMENT_API_URL=http://localhost:8001
VITE_MUSIC_API_URL=http://localhost:8002
VITE_LEGACY_API_URL=http://localhost:8000

# Fallback to original backend URL (for backward compatibility)
VITE_BACKEND_API=http://localhost:8000

# Application Settings
VITE_APP_NAME=Music Platform
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_NEW_PAYMENT_DOMAIN=true
VITE_ENABLE_NEW_MUSIC_DOMAIN=true
VITE_ENABLE_LEGACY_FALLBACK=true

# Payment Configuration
VITE_DEFAULT_PAYMENT_PROVIDER=telebirr
VITE_PAYMENT_TIMEOUT=15000
VITE_ENABLE_PAYMENT_REDIRECTS=true

# Music Configuration
VITE_ENABLE_SOCIAL_FEATURES=true
VITE_ENABLE_MARKETPLACE=true
VITE_ENABLE_SEARCH=true
VITE_MAX_FILE_SIZE_MB=100

# UI Configuration
VITE_THEME=telegram
VITE_LANGUAGE=en
VITE_TIMEZONE=Africa/Addis_Ababa

# Development Settings
VITE_ENABLE_DEBUG=true
VITE_ENABLE_CONSOLE_LOGS=true
VITE_API_MOCKING=false

# Security Settings
VITE_ENABLE_CORS=true
VITE_API_RATE_LIMIT=true
VITE_ENABLE_ANALYTICS=true
