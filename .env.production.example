# Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://music_user:secure_password@localhost:5432/music_platform
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis Cache Configuration
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_DEFAULT_TTL=3600

# Celery Configuration
CELERY_BROKER_URL=amqp://admin:admin@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Application Settings
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-production-key-change-this
ADMIN_API_KEY=your-admin-api-key

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Payment Provider Settings
PAYMENT_ENABLED=true
TELEBIRR_ENABLED=true
CHAPA_ENABLED=true
CBE_BANK_ENABLED=false
MANUAL_BANK_ENABLED=false

# Telebirr Configuration
TELEBIRR_BASE_URL=https://api.telebirr.et
TELEBIRR_APP_ID=your_app_id
TELEBIRR_APP_SECRET=your_app_secret
TELEBIRR_MERCHANT_CODE=your_merchant_code
TELEBIRR_SHORT_CODE=your_short_code
TELEBIRR_TEST_MODE=false

# Chapa Configuration
CHAPA_BASE_URL=https://api.chapa.co
CHAPA_SECRET_KEY=your_secret_key
CHAPA_WEBHOOK_SECRET=your_webhook_secret
CHAPA_MERCHANT_ID=your_merchant_id
CHAPA_TEST_MODE=false

# Monitoring and Observability
GRAFANA_USER=admin
GRAFANA_PASSWORD=secure_grafana_password

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASS=secure_rabbitmq_password

# PostgreSQL Configuration
POSTGRES_USER=music_user
POSTGRES_PASSWORD=secure_postgres_password
